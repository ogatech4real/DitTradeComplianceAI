# Backend origin — no trailing slash. Required on Vercel (Production + Preview).
# Local dev defaults to http://localhost:8000 when unset (see src/lib/api/config.ts).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Use contract-faithful mocks (no FastAPI required). Great for Vercel previews + UI work.
NEXT_PUBLIC_USE_MOCK_API=false

# When USE_MOCK_API=true, optionally seed /results/latest with MOCK_SCREENING_SUCCESS on first fetch.
NEXT_PUBLIC_MOCK_PREFILL_RESULTS=false
